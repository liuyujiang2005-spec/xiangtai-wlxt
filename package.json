{
  "name": "xiangtai-logistics",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "postinstall": "prisma generate",
    "prebuild": "prisma generate",
    "dev": "prisma generate && node --max-old-space-size=4096 --max-semi-space-size=64 ./node_modules/next/dist/bin/next dev --webpack",
    "dev:3001": "next dev --webpack -p 3001",
    "dev:turbo": "next dev --turbopack",
    "build": "prisma generate && next build --webpack",
    "start:local": "next start",
    "start": "tsx scripts/validate-env.ts && prisma migrate deploy && next start",
    "lint": "eslint",
    "seed:users": "tsx scripts/seed-users.ts",
    "db:list-users": "tsx scripts/list-users.ts",
    "db:unban-all": "tsx scripts/unban-all.ts",
    "password:reset": "tsx scripts/reset-password.ts",
    "db:cleanup-tracking": "tsx scripts/cleanup-tracking-numbers.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "husky": "^9.1.7",
    "prisma": "^7.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
